    "\n",
    "# --- Load Weighted Vectors ---\n",
    "print(\"Loading weighted vectors...\")\n",
    "w_indices, X_w = load_dense('weighted_vectors.txt')\n",
    "y_w = df.loc[w_indices, 'label'].values.astype(int)\n",
    "print(f\"  Weighted: X={X_w.shape}, y={y_w.shape}\")"
