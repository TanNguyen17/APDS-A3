    "b2 = ax.bar(x + w/2, avg['ΔF1 (+Title+Extra)'], w, label='+Title+Extra', color='darkorange', alpha=0.85)\n",
    "ax.axhline(0, color='black', linewidth=0.8, linestyle='--')\n",
    "ax.set_xticks(x)\n",
